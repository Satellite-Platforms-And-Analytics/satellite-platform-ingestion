# Satellite Platform — Ingestion Pipeline
# Copy to .env and fill in your values
# Never commit .env to git

# ── Database ──────────────────────────────────────────────────────────────────
# Phase 1: Supabase or Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/satellite_platform

# Local SQLite fallback (used until PostgreSQL is configured)
SQLITE_PATH=D:/Databases/satellite_platform.db

# ── Space-Track (optional — CelesTrak is primary) ─────────────────────────────
SPACETRACK_USER=your@email.com
SPACETRACK_PASS=yourpassword

# ── Copernicus / Sentinel-2 ───────────────────────────────────────────────────
COPERNICUS_USER=your@email.com
COPERNICUS_PASS=yourpassword

# ── NASA Earthdata ────────────────────────────────────────────────────────────
EARTHDATA_USER=yourusername
EARTHDATA_PASS=yourpassword

# ── QGIS (for JP2 conversion) ─────────────────────────────────────────────────
# Auto-detected from C:\Program Files\QGIS*\bin\gdal_translate.exe
# Override if QGIS is installed in a non-standard location
# QGIS_GDAL_TRANSLATE=C:\Program Files\QGIS 3.44.11\bin\gdal_translate.exe

# ── Local data paths ──────────────────────────────────────────────────────────
SATELLITE_DATA_BASE=D:/SatelliteData
GIS_DATA_BASE=D:/GIS
MODELS_BASE=D:/Models

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
CSV_LOG_PATH=D:/Databases/ingestion_log.csv

# ── Scheduling ────────────────────────────────────────────────────────────────
TLE_REFRESH_HOURS=2
POSITION_UPDATE_MINUTES=5
